.detail_button_box{
  padding: 0px 1px 0px 1px;
  width: 100%;
  bottom: 180rpx;
  position: fixed;
  display: flex;
  flex-direction:row;
  justify-content: space-around;
  /* opacity: 0.8;   */
}
.again_btn{
  margin: 0px 10px 0px 10px;
  padding: 1px 1px;
  background-color: #1678ff;
  border-radius: 30px;
  font-size:15px ;
  color:white;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
}
.share_btn{
  margin: 0px 10px 0px 10px;
  padding: 1px 1px;
  background-color: white;
  border-radius: 30px;
  font-size:15px ;
  color:#1678ff;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
}

.img_again{
  height: 28px;
  width: 28px;
  margin-right: 4px;
}
.img_share{
  height: 40px;
  width: 40px;
}
