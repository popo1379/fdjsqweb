/* 自定义页面样式 */
.input-field:focus {
  border-color: #1E90FF;
  box-shadow: 0 0 8rpx rgba(30, 144, 255, 0.3);
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}
/* 重置默认样式 */
page, view, text, input, button, icon {
  box-sizing: border-box;
}

/* 全局样式 */
page {
  --color-primary: #2563EB;
  --color-primary-light: #3B82F6;
  --color-secondary: #7C3AED;
  --color-success: #10B981;
  --color-warning: #F59E0B;
  --color-danger: #EF4444;
  --color-surface: #FFFFFF;
  --color-text-primary: #1F2937;
  --color-text-secondary: #6B7280;
  --color-border: #E5E7EB;
  --color-background: #F9FAFB;
  
  font-family: -apple-system, BlinkMacSystemFont, 
               'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  background-color: var(--color-background);
  color: var(--color-text-primary);
  min-height: 100vh;
}

/* 容器样式 */
.container {
  padding: 24rpx;
  padding-bottom: 100rpx;
}

/* 卡片样式 */
.card {
  background-color: var(--color-surface);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.05);
  padding: 32rpx;
  margin-bottom: 32rpx;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 8rpx;
  background: linear-gradient(90deg, var(--color-primary), var(--color-secondary));
}

/* 主按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
  color: white;
  border-radius: 12rpx;
  padding: 28rpx;
  text-align: center;
  font-weight: 500;
  font-size: 32rpx;
  margin-top: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(59, 130, 246, 0.3);
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  border: none;
  width: 100%;
  position: relative;
  overflow: hidden;
  z-index: 1;
}

.btn-primary::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, rgba(255,255,255,0.2), transparent);
  opacity: 0;
  transition: opacity 0.3s ease;
  z-index: -1;
}

.btn-primary:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 10rpx rgba(59, 130, 246, 0.2);
}

.btn-primary:active::after {
  opacity: 1;
}

/* 输入组样式 */
.input-group {
  margin-bottom: 32rpx;
}

.input-label {
  font-size: 28rpx;
  margin-bottom: 16rpx;
  color: var(--color-text-secondary);
  display: flex;
  align-items: center;
  font-weight: 500;
}

.input-label .icon {
  margin-right: 12rpx;
  width: 32rpx;
  height: 32rpx;
}

.input-field {
  height: 92rpx;
  border: 1.5rpx solid var(--color-border);
  border-radius: 12rpx;
  padding: 0 28rpx;
  font-size: 32rpx;
  background: #FFFFFF;
  width: 100%;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
}

.input-field:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 3rpx rgba(37, 99, 235, 0.1);
  outline: none;
}

.input-tip {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 12rpx;
}

/* 选择器组样式 */
.selector-group {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 16rpx;
}

.selector-item {
  flex: 1;
  min-width: 40%;
  text-align: center;
  padding: 24rpx 16rpx;
  border: 1.5rpx solid var(--color-border);
  border-radius: 12rpx;
  background-color: #FFFFFF;
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.selector-item.active {
  border-color: var(--color-primary);
  background-color: rgba(37, 99, 235, 0.08);
  color: var(--color-primary);
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.1);
}

/* Tab页签样式 */
.tab-container {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
  background: var(--color-surface);
  border-radius: 24rpx;
  padding: 16rpx 0;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.03);
}

.tab-item {
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  position: relative;
  font-weight: 500;
  color: var(--color-text-secondary);
  transition: color 0.3s ease;
}

.tab-item.active {
  color: var(--color-primary);
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60%;
  height: 4rpx;
  background: linear-gradient(90deg, var(--color-primary), var(--color-secondary));
  border-radius: 4rpx;
}

/* 章节标题样式 */
.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 40rpx;
  padding-bottom: 24rpx;
  border-bottom: 1.5rpx solid var(--color-border);
  position: relative;
  display: flex;
  align-items: center;
}

.section-title::after {
  content: '';
  position: absolute;
  bottom: -1.5rpx;
  left: 0;
  width: 100rpx;
  height: 3rpx;
  background: linear-gradient(90deg, var(--color-primary), var(--color-secondary));
  border-radius: 3rpx;
}

/* 警告提示样式 */
.warning {
  color: var(--color-warning);
  font-size: 26rpx;
  padding: 12rpx 0;
  display: flex;
  align-items: center;
}

.warning .icon {
  margin-right: 8rpx;
  width: 32rpx;
  height: 32rpx;
}

/* 加载动画 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.card {
  animation: fadeIn 0.5s ease-out;
}