<view class="container">
  <view class="card">
    <view wx:if="{{type === 'used'}}">
      <view class="section-title">
        <icon type="home" size="24" /> 二手房税费明细
      </view>
      
      <!-- 房屋基本信息卡片 -->
      <view class="info-card">
        <view class="info-row">
          <text>面积：</text>
          <text class="info-value">{{houseData.houseArea}} m²</text>
        </view>
        <view class="info-row">
          <text>总价：</text>
          <text class="info-value">{{houseData.totalPrice}} 万元</text>
        </view>
        <view class="info-row">
          <text>登记价：</text>
          <text class="info-value">{{houseData.originalPrice}} 万元</text>
        </view>
        <view class="info-grid">
          <view class="grid-item">
            <text class="grid-label">购置年限</text>
            <text class="grid-value">{{houseData.yearsOption}}</text>
          </view>
          <view class="grid-item">
            <text class="grid-label">房产类型</text>
            <text class="grid-value">{{houseData.houseType}}</text>
          </view>
          <view class="grid-item">
            <text class="grid-label">卖家持有</text>
            <text class="grid-value">{{houseData.sellerSituation}}</text>
          </view>
          <view class="grid-item">
            <text class="grid-label">买家首套</text>
            <text class="grid-value">{{houseData.isFirstBuy}}</text>
          </view>
        </view>
      </view>
      
      <!-- 税费明细 -->
      <view class="section-title">
        <icon type="pay" size="24" /> 税费详情
      </view>
      
      <view class="tax-details">
        <view class="tax-item">
          <view class="tax-header">
            <icon type="paycircle" size="28" color="#3B82F6" />
            <text class="tax-name">增值税</text>
            <text class="tax-value">{{taxResult.vat}}</text>
          </view>
          <text class="tax-explanation">{{taxResult.vatExplanation}}</text>
        </view>
        
        <view class="tax-item">
          <view class="tax-header">
            <icon type="paycircle" size="28" color="#8B5CF6" />
            <text class="tax-name">增值税附加</text>
            <text class="tax-value">{{taxResult.vatAdd}}</text>
          </view>
          <text class="tax-explanation">{{taxResult.vatAddExplanation}}</text>
        </view>
        
        <view class="tax-item">
          <view class="tax-header">
            <icon type="paycircle" size="28" color="#10B981" />
            <text class="tax-name">个人所得税</text>
            <text class="tax-value">{{taxResult.incomeTax}}</text>
          </view>
          <text class="tax-explanation">{{taxResult.incomeTaxExplanation}}</text>
        </view>
        
        <view class="tax-item">
          <view class="tax-header">
            <icon type="paycircle" size="28" color="#F59E0B" />
            <text class="tax-name">契税</text>
            <text class="tax-value">{{taxResult.deedTax}}</text>
          </view>
          <text class="tax-explanation">{{taxResult.deedTaxExplanation}}</text>
        </view>
        
        <view class="tax-item">
          <view class="tax-header">
            <icon type="paycircle" size="28" color="#EF4444" />
            <text class="tax-name">印花税</text>
            <text class="tax-value">{{taxResult.stampDuty}}</text>
          </view>
          <text class="tax-explanation">{{taxResult.stampDutyExplanation}}</text>
        </view>
        
        <view class="tax-item">
          <view class="tax-header">
            <icon type="paycircle" size="28" color="#6B7280" />
            <text class="tax-name">登记费</text>
            <text class="tax-value">{{taxResult.registrationFee}}</text>
          </view>
        </view>
      </view>
      
      <!-- 总计 -->
      <view class="tax-total">
        <view class="total-label">
          <icon type="pay" size="32" />
          <text>总计税费</text>
        </view>
        <view class="total-value">{{taxResult.totalTax}}</view>
      </view>
    </view>

    <view wx:else>
      <view class="section-title">
        <icon type="home" size="24" /> 新房税费明细
      </view>
      
      <!-- 房屋基本信息卡片 -->
      <view class="info-card">
        <view class="info-row">
          <text>面积：</text>
          <text class="info-value">{{houseData.houseArea}} m²</text>
        </view>
        <view class="info-row">
          <text>总价：</text>
          <text class="info-value">{{houseData.totalPrice}} 万元</text>
        </view>
        <view class="info-grid">
          <view class="grid-item">
            <text class="grid-label">房产类型</text>
            <text class="grid-value">{{houseData.houseType}}</text>
          </view>
          <view class="grid-item">
            <text class="grid-label">购房情况</text>
            <text class="grid-value">{{houseData.buyerSituation}}</text>
          </view>
        </view>
      </view>
      
      <!-- 费用明细 -->
      <view class="section-title">
        <icon type="pay" size="24" /> 费用详情
      </view>
      
      <view class="tax-details">
        <view class="tax-item">
          <view class="tax-header">
            <icon type="paycircle" size="28" color="#3B82F6" />
            <text class="tax-name">房屋总款</text>
            <text class="tax-value">{{taxResult.totalPrice}} 万元</text>
          </view>
        </view>
        
        <view class="tax-item">
          <view class="tax-header">
            <icon type="paycircle" size="28" color="#F59E0B" />
            <text class="tax-name">契税</text>
            <text class="tax-value">{{taxResult.deedTax}}</text>
          </view>
          <text class="tax-explanation">{{taxResult.deedTaxExplanation}}</text>
        </view>
        
        <view class="tax-item">
          <view class="tax-header">
            <icon type="paycircle" size="28" color="#10B981" />
            <text class="tax-name">维修基金</text>
            <text class="tax-value">{{taxResult.maintenanceFund}}</text>
          </view>
          <text class="tax-explanation">{{taxResult.maintenanceFundExplanation}}</text>
        </view>
        
        <view class="tax-item">
          <view class="tax-header">
            <icon type="paycircle" size="28" color="#8B5CF6" />
            <text class="tax-name">产权登记费</text>
            <text class="tax-value">{{taxResult.propertyRegistrationFee}}</text>
          </view>
        </view>
        
        <view class="tax-item">
          <view class="tax-header">
            <icon type="paycircle" size="28" color="#6B7280" />
            <text class="tax-name">交易手续费</text>
            <text class="tax-value">{{taxResult.transactionFee}}</text>
          </view>
          <text class="tax-explanation">{{taxResult.transactionFeeExplanation}}</text>
        </view>
        
        <view class="tax-item">
          <view class="tax-header">
            <icon type="paycircle" size="28" color="#EF4444" />
            <text class="tax-name">配图费</text>
            <text class="tax-value">{{taxResult.mappingFee}}</text>
          </view>
        </view>
        
        <view class="tax-item">
          <view class="tax-header">
            <icon type="paycircle" size="28" color="#6366F1" />
            <text class="tax-name">印花税</text>
            <text class="tax-value">{{taxResult.stampDuty}}</text>
          </view>
          <text class="tax-explanation">{{taxResult.stampDutyExplanation}}</text>
        </view>
      </view>
      
      <!-- 总计 -->
      <view class="tax-total">
        <view class="total-label">
          <icon type="pay" size="32" />
          <text>税费总计</text>
        </view>
        <view class="total-value">{{taxResult.totalCost}}</view>
      </view>
    </view>
  </view>

  <button class="btn-primary" bindtap="goBack">
    <icon type="back" size="20" /> 返回修改
  </button>
</view>