/* 信息卡片样式 */
.info-card {
  background: rgba(249, 250, 251, 0.7);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 40rpx;
  border: 1.5rpx solid #E5E7EB;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 24rpx 0;
  font-size: 32rpx;
  border-bottom: 1.5rpx solid #F3F4F6;
}

.info-row:last-child {
  border-bottom: none;
}

.info-value {
  font-weight: 600;
  color: var(--color-primary);
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  margin-top: 24rpx;
}

.grid-item {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  border: 1.5rpx solid #F3F4F6;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.grid-label {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.grid-value {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

/* 税费详情样式 */
.tax-details {
  margin-bottom: 48rpx;
}

.tax-item {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  border-left: 8rpx solid;
  transition: all 0.3s ease;
}

.tax-item:nth-child(1) { border-left-color: #3B82F6; }
.tax-item:nth-child(2) { border-left-color: #8B5CF6; }
.tax-item:nth-child(3) { border-left-color: #10B981; }
.tax-item:nth-child(4) { border-left-color: #F59E0B; }
.tax-item:nth-child(5) { border-left-color: #EF4444; }
.tax-item:nth-child(6) { border-left-color: #6B7280; }

.tax-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.tax-name {
  flex: 1;
  font-size: 32rpx;
  font-weight: 500;
  margin-left: 16rpx;
}

.tax-value {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.tax-explanation {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

/* 总计样式 */
.tax-total {
  background: linear-gradient(135deg, #F0FDFF, #F9F5FF);
  border-radius: 16rpx;
  padding: 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
  border: 1.5rpx solid #E0F2FE;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.total-label {
  display: flex;
  align-items: center;
  font-size: 36rpx;
  font-weight: 600;
}

.total-label text {
  margin-left: 16rpx;
}

.total-value {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-primary);
}

/* 动画效果 */
@keyframes slideIn {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.info-card,
.tax-item,
.tax-total {
  animation: slideIn 0.4s ease-out;
}

/* 渐入延迟动画 */
.tax-item:nth-child(1) { animation-delay: 0.1s; }
.tax-item:nth-child(2) { animation-delay: 0.2s; }
.tax-item:nth-child(3) { animation-delay: 0.3s; }
.tax-item:nth-child(4) { animation-delay: 0.4s; }
.tax-item:nth-child(5) { animation-delay: 0.5s; }
.tax-item:nth-child(6) { animation-delay: 0.6s; }
.tax-total { animation-delay: 0.7s; }
/* 重置默认样式 */
page, view, text, input, button, icon {
  box-sizing: border-box;
}

/* 全局样式 */
page {
  --color-primary: #2563EB;
  --color-primary-light: #3B82F6;
  --color-secondary: #7C3AED;
  --color-success: #10B981;
  --color-warning: #F59E0B;
  --color-danger: #EF4444;
  --color-surface: #FFFFFF;
  --color-text-primary: #1F2937;
  --color-text-secondary: #6B7280;
  --color-border: #E5E7EB;
  --color-background: #F9FAFB;
  
  font-family: -apple-system, BlinkMacSystemFont, 
               'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  background-color: var(--color-background);
  color: var(--color-text-primary);
  min-height: 100vh;
}

/* 容器样式 */
.container {
  padding: 24rpx;
  padding-bottom: 100rpx;
}

/* 卡片样式 */
.card {
  background-color: var(--color-surface);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.05);
  padding: 32rpx;
  margin-bottom: 32rpx;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 8rpx;
  background: linear-gradient(90deg, var(--color-primary), var(--color-secondary));
}

/* 主按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
  color: white;
  border-radius: 12rpx;
  padding: 28rpx;
  text-align: center;
  font-weight: 500;
  font-size: 32rpx;
  margin-top: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(59, 130, 246, 0.3);
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  border: none;
  width: 100%;
  position: relative;
  overflow: hidden;
  z-index: 1;
}

.btn-primary::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, rgba(255,255,255,0.2), transparent);
  opacity: 0;
  transition: opacity 0.3s ease;
  z-index: -1;
}

.btn-primary:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 10rpx rgba(59, 130, 246, 0.2);
}

.btn-primary:active::after {
  opacity: 1;
}

/* 输入组样式 */
.input-group {
  margin-bottom: 32rpx;
}

.input-label {
  font-size: 28rpx;
  margin-bottom: 16rpx;
  color: var(--color-text-secondary);
  display: flex;
  align-items: center;
  font-weight: 500;
}

.input-label .icon {
  margin-right: 12rpx;
  width: 32rpx;
  height: 32rpx;
}

.input-field {
  height: 92rpx;
  border: 1.5rpx solid var(--color-border);
  border-radius: 12rpx;
  padding: 0 28rpx;
  font-size: 32rpx;
  background: #FFFFFF;
  width: 100%;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
}

.input-field:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 3rpx rgba(37, 99, 235, 0.1);
  outline: none;
}

.input-tip {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 12rpx;
}

/* 选择器组样式 */
.selector-group {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 16rpx;
}

.selector-item {
  flex: 1;
  min-width: 40%;
  text-align: center;
  padding: 24rpx 16rpx;
  border: 1.5rpx solid var(--color-border);
  border-radius: 12rpx;
  background-color: #FFFFFF;
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.selector-item.active {
  border-color: var(--color-primary);
  background-color: rgba(37, 99, 235, 0.08);
  color: var(--color-primary);
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.1);
}

/* Tab页签样式 */
.tab-container {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
  background: var(--color-surface);
  border-radius: 24rpx;
  padding: 16rpx 0;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.03);
}

.tab-item {
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  position: relative;
  font-weight: 500;
  color: var(--color-text-secondary);
  transition: color 0.3s ease;
}

.tab-item.active {
  color: var(--color-primary);
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60%;
  height: 4rpx;
  background: linear-gradient(90deg, var(--color-primary), var(--color-secondary));
  border-radius: 4rpx;
}

/* 章节标题样式 */
.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 40rpx;
  padding-bottom: 24rpx;
  border-bottom: 1.5rpx solid var(--color-border);
  position: relative;
  display: flex;
  align-items: center;
}

.section-title::after {
  content: '';
  position: absolute;
  bottom: -1.5rpx;
  left: 0;
  width: 100rpx;
  height: 3rpx;
  background: linear-gradient(90deg, var(--color-primary), var(--color-secondary));
  border-radius: 3rpx;
}

/* 警告提示样式 */
.warning {
  color: var(--color-warning);
  font-size: 26rpx;
  padding: 12rpx 0;
  display: flex;
  align-items: center;
}

.warning .icon {
  margin-right: 8rpx;
  width: 32rpx;
  height: 32rpx;
}

/* 加载动画 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.card {
  animation: fadeIn 0.5s ease-out;
}