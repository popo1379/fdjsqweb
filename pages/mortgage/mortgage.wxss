page,
.page,
.page__bd{
    height: 100%;
}
.page__bd{
    padding-bottom: 0;}

.weui-tab__content{
    padding-top: 15rpx;
} 
.view_policy{
    margin-top: 10rpx;
    margin-right: 15px;
    text-align:right;
}
.text_policy{
    color: royalblue;
}
.page__desc {
  text-indent: 2em;
  color: red;
}
.view_term{
    height:100% ;
    border-top:1rpx solid #d9d9d9;
    padding:10px 15px 0px 15px ;
  }
.slider_term{
    margin-bottom: 15px;
}
.view_cell{
    border-top:1rpx solid #d9d9d9;
}
.view-ares{
    margin-top: 10rpx;
    margin-left: 20rpx;
    margin-right: 20rpx;
    display: flex;
    /* 让元素水平显示 */
    flex-direction: row;
    /* 元素位于横轴两端 */
    justify-content: space-between;
}
.btn_empty{
    background-color:white;
    color: #6C6C6C	;
}
.btn_ares{
    background-color:#1678ff;
    color: white;
    width: 70%;
}
.view_share{
    margin-left: 20rpx;
    margin-right: 20rpx;
}
.btn_share{
    margin-top: 8rpx;
    background-color:white;
    color:#1678ff ;
    padding: 1rpx;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
}
.img_share{
    height: 40px;
    width: 40px;
}
.view_latestLpr{
    margin-left: 20rpx;
    margin-right: 20rpx;
    display: flex;
    /* 让元素水平显示 */
    flex-direction:column;
    margin-top: 10rpx;
}
.view_latestLpr_inside{
    background-color:white;
    height:150rpx ;
    border-radius: 5px;
    display: flex;
    flex-direction: row;
    justify-content: space-around;
    align-items: center;
}
.view_lateslpr_content{
    display: flex;
    flex-direction: column;
    align-items: center;
}
.text_lprname{
    font-size: small;
    margin: 10rpx 0;
    color: #999;
}
.text_lprcontent{
    font-size:40rpx;
    margin-top: 5rpx;
    font-weight:bold; 
    color: #5B5B5B;

}
.topbanner{
    margin-top: 15rpx;
}
.img_nullbtn{
    height: 20px;
    width: 20px;
}
.banner_box{
    margin-left: 20rpx;
    margin-right: 20rpx;
    display: flex;
    /* 让元素水平显示 */
    flex-direction:column;
    margin-top: 1rpx;
}

.banner_item{
    width:100%;
    border-radius: 5px;
}
.newlist_box{
  margin-left: 20rpx;
  margin-right: 20rpx;
  display: flex;
  /* 让元素水平显示 */
  flex-direction:column;
  margin-top: 5rpx;
}
.new_item{
  background-color: white ;
  height: 150rpx;
  margin-bottom: 10rpx;
  padding: 10rpx 25rpx 10rpx 20rpx;
  border-radius: 5px;
  display: flex;
  flex-direction:row;
  justify-content: column;
  align-items: center;
}
.new_img{
  height: 150rpx;
  width:200rpx;
  border-radius: 5px;
  overflow:hidden;
  display:inline-block;
}
.new_titlebox{
  margin-left: 20rpx;
  height: 100%;
  width: 500rpx;
}
.new_title{
  color: rgb(58, 54, 54);
  font-size:30rpx;
}
.view_yearsbtnbox{
  display: flex;
  /* 让元素水平显示 */
  flex-direction: row;
  /* 元素位于横轴两端 */
  justify-content: space-between;
}
.btn_years{
  margin-top: 10rpx;
  font-size: 30rpx;
  color:#545557;
  width: 100%;
  font-weight:500;
}
.text_morename{
  font-size: small;
  margin: 5rpx 0rpx 10rpx 0rpx;
  color: #999;
}