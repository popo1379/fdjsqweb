/* 页面样式 */
.container {
  margin-left: 20rpx;
  margin-right: 20rpx;
  display: flex;
  /* 让元素水平显示 */
  flex-direction:column;
  margin-top: 10rpx;
}
/* 更多工具卡片样式 */
.card {
  width: 90%;
  background-color: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
  padding: 40rpx;
}

/* 卡片头部样式 */
.card-header {
  text-align: center;
  margin-bottom: 60rpx;
}

.card-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.card-subtitle {
  display: block;
  font-size: 28rpx;
  color: #999999;
}

/* 按钮容器 - 并排布局 */
.button-container.row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  gap: 30rpx;
}

/* 按钮通用样式 */
.button {
  flex: 1; /* 等分宽度 */
  height: 40rpx; /* 增加高度以适应并排布局 */
  border-radius: 16rpx;
  display: flex;
  flex-direction: column; /* 垂直排列图标和文字 */
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.button:active {
  transform: scale(0.98);
}

/* 按钮图标 */
.button-icon {
  margin-bottom: 10rpx; /* 图标和文字之间的间距 */
  z-index: 2;
}

/* 按钮文字 */
.button-text {
  font-size: 24rpx; /* 稍微减小字号以适应宽度 */
  font-weight: bold;
  color: white;
  z-index: 2;
  text-align: center;
  line-height: 1.3;
}

/* 提前还贷按钮样式 */
.loan-btn {
  background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
  box-shadow: 0 10rpx 20rpx rgba(106, 17, 203, 0.3);
}

/* 房屋税费按钮样式 */
.tax-btn {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  box-shadow: 0 10rpx 20rpx rgba(17, 153, 142, 0.3);
}

/* 按钮的渐变覆盖层（用于悬停效果） */
.button::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(rgba(255, 255, 255, 0.2), rgba(255, 255, 255, 0));
  opacity: 0;
  transition: opacity 0.3s ease;
}

.button:active::after {
  opacity: 1;
}

/* 卡片底部样式 */
.card-footer {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 30rpx;
}

.footer-line {
  flex: 1;
  height: 1rpx;
  background-color: #eeeeee;
}

.footer-text {
  padding: 0 30rpx;
  font-size: 24rpx;
  color: #999999;
}
/* 遮罩弹窗样式 */
/* 基础样式 */
page {
  background-color: #f6f8fb;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  color: #333;
  padding: 0;
  margin: 0;
  height: 100%;
}

/* 头部区域 */
.header {
  padding: 60rpx 0 40rpx;
  text-align: center;
}

.title {
  font-size: 46rpx;
  font-weight: bold;
  color: #2c3e50;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #7d8ca1;
}

/* 利率显示区域 */
.interest-display {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 60rpx;
  background: #f9fbfe;
  padding: 32rpx;
  border-radius: 16rpx;
}

.label {
  font-size: 32rpx;
  color: #7d8ca1;
}

.value {
  font-size: 64rpx;
  font-weight: bold;
  color: #3498db;
  margin-left: 16rpx;
}

/* 选择按钮 */
.select-btn {
  background: linear-gradient(135deg, #3498db, #1d6fa5);
  color: white;
  height: 96rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 500;
  box-shadow: 0 10rpx 20rpx rgba(52, 152, 219, 0.2);
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}

.select-btn:active {
  transform: scale(0.98);
  box-shadow: 0 5rpx 10rpx rgba(52, 152, 219, 0.2);
}

.btn-icon {
  font-size: 42rpx;
  margin-right: 20rpx;
  position: relative;
  top: -2rpx;
}

/* 提示区域 */
.tip {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 50rpx 0 30rpx;
  font-size: 26rpx;
  color: #95a5c0;
}

.tip-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

/* ============ 弹窗样式 ============ */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
  transition: opacity 0.3s ease;
}

.modal-content {
  background: #fff;
  width: 100%;
  border-top-left-radius: 5rpx;
  border-top-right-radius: 5rpx;
  padding: 30rpx;
  padding-bottom: 60rpx;
  box-sizing: border-box;
  max-height: 85vh;
  overflow-y: auto;
  position: relative;
  animation: slideUp 0.35s ease-out forwards;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

/* 弹窗标题区域 */
.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #f0f3f7;
  margin-bottom: 20rpx;
}

.modal-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #2c3e50;
}

/* 关闭按钮 */
.close-btn {
  width: 70rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  color: #95a5c0;
  border-radius: 50%;
  transition: all 0.3s;
}

.close-btn:active {
  background: #f8fafc;
  color: #e74c3c;
}

/* 区域标题 */
.section {
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  color: #2c3e50;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.section-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
}

/* 预设利率区域 */
.preset-options {
  border-radius: 16rpx;
  overflow: hidden;
}

.preset-option {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  background: #f8fafc;
  border-bottom: 1rpx solid #f0f3f7;
  transition: all 0.3s;
}

.preset-option:last-child {
  border-bottom: none;
}

.preset-option.active {
  background: #e7f4fe;
  color: #2980b9;
  font-weight: 500;
}

.option-icon {
  width: 36rpx;
  height: 36rpx;
}

/* 输入区域 */
.input-area {
  position: relative;
  margin-bottom: 10rpx;
}

.custom-input {
  background: #ffffff;
  height: 100rpx;
  padding: 0 120rpx 0 40rpx;
  border-radius: 16rpx;
  font-size: 34rpx;
  color: #2c3e50;
  caret-color: #3498db;
  border: 2rpx solid #e8edf4;
  transition: all 0.3s;
}

.custom-input:focus {
  border-color: #3498db;
  background: #fff;
}

.input-placeholder {
  color: #c1cbd8;
}

.unit {
  position: absolute;
  right: 40rpx;
  top: 32rpx;
  color: #7d8ca1;
  font-size: 34rpx;
}

.hint {
  font-size: 26rpx;
  color: #95a5c0;
  padding: 0 rpx;
}

/* 确认按钮 */
.confirm-btn {
  background: linear-gradient(135deg, #2ecc71, #27ae60);
  color: white;
  height: 90rpx;
  line-height: 90rpx;
  text-align: center;
  border-radius: 16rpx;
  font-size: 34rpx;
  font-weight: 500;
  margin-top: 40rpx;
  box-shadow: 0 10rpx 20rpx rgba(46, 204, 113, 0.2);
  transition: all 0.3s;
}

.confirm-btn:active {
  transform: scale(0.98);
  box-shadow: 0 5rpx 15rpx rgba(46, 204, 113, 0.3);
}
/* 总额角标样式 */
.unit-badge {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  background-color: #ff6b00;
  color: white;
  border-radius: 6rpx;
  padding: 4rpx 12rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  min-width: 40rpx;
  justify-content: center;
  z-index: 2; /* 确保在输入文字上方 */
}

.corner {
  position: absolute;
  left: -8rpx;
  top: 50%;
  transform: translateY(-50%) rotate(45deg);
  width: 16rpx;
  height: 16rpx;
  background-color: #ff6b00;
}

.zonge_input{
  padding-top:5rpx;
  padding-bottom:5rpx;
}
