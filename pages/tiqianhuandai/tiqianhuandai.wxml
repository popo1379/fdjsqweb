<view class="container">
  <!-- 标题 -->
  <view class="header">
    <text class="title">提前还款计算器</text>
    <text class="subtitle">准确计算提前还款能省多少钱</text>
  </view>

  <!-- 贷款类型选择 -->
  <view class="form-section">
    <text class="section-title">贷款类型</text>
    <radio-group class="radio-group" bindchange="onLoanTypeChange">
      <label class="radio" wx:for="{{loanTypes}}" wx:key="value">
        <radio value="{{item.value}}" checked="{{item.value === loanType}}" color="#4a7dff" />{{item.name}}
      </label>
    </radio-group>
  </view>

  <!-- 还款方式选择 -->
  <view class="form-section">
    <text class="section-title">还款方式</text>
    <radio-group class="radio-group" bindchange="onRepaymentChange">
      <label class="radio" wx:for="{{repaymentTypes}}" wx:key="value">
        <radio value="{{item.value}}" checked="{{item.value === repaymentType}}" color="#4a7dff" />{{item.name}}
      </label>
    </radio-group>
  </view>

  <!-- 贷款信息表单 -->
  <view class="form-section">
    <text class="section-title">贷款信息</text>
    
    <view class="form-item">
      <text class="label">贷款金额(万元)</text>
      <input 
        class="input" 
        type="number" 
        value="{{loanAmount}}"
        placeholder="请输入贷款金额" 
        bindinput="onLoanAmountChange" 
      />
    </view>
    
    <view class="form-item">
      <text class="label">贷款年限</text>
      <input 
        class="input" 
        type="number" 
        value="{{loanYears}}"
        placeholder="请输入贷款年限" 
        bindinput="onLoanYearsChange" 
      />
    </view>
    
    <view class="form-item">
      <text class="label">贷款利率(%)</text>
      <input 
        class="input" 
        type="number" 
        value="{{loanRate}}"
        placeholder="请输入贷款利率" 
        bindinput="onLoanRateChange" 
      />
    </view>
    
    <view class="form-item">
      <text class="label">首期还款时间</text>
      <picker 
        class="picker" 
        mode="date" 
        fields="month" 
        value="{{firstRepaymentDate}}"
        bindchange="onFirstRepaymentChange"
      >
        <view class="picker-value">{{firstRepaymentDate || '请选择'}}</view>
      </picker>
    </view>
    
    <view class="form-item">
      <text class="label">提前还款时间</text>
      <picker 
        class="picker" 
        mode="date" 
        fields="month" 
        value="{{prepaymentDate}}"
        bindchange="onPrepaymentChange"
      >
        <view class="picker-value">{{prepaymentDate || '请选择'}}</view>
      </picker>
    </view>
  </view>
  
  <!-- 提前还款方式选择 -->
  <view class="form-section">
    <text class="section-title">提前还款方式</text>
    <radio-group class="radio-group" bindchange="onPrepaymentTypeChange">
      <label class="radio" wx:for="{{prepaymentTypes}}" wx:key="value">
        <radio value="{{item.value}}" checked="{{item.value === prepaymentType}}" color="#4a7dff" />{{item.name}}
      </label>
    </radio-group>
  </view>
  
  <!-- 提前还款金额（仅部分还款时显示） -->
  <view class="form-section" wx:if="{{prepaymentType === 'partial'}}">
    <view class="form-item">
      <text class="label">提前结清金额(元)</text>
      <input 
        class="input" 
        type="number" 
        value="{{prepaymentAmount}}"
        placeholder="请输入提前结清金额" 
        bindinput="onPrepaymentAmountChange" 
      />
    </view>
  </view>
  
  <!-- 温馨提示 -->
  <view class="tip" wx:if="{{prepaymentType === 'full'}}">
    <text>温馨提示：全额还款无需输入还款金额，系统会自动使用剩余本金作为还款金额</text>
  </view>
  
  <!-- 表单验证提示 -->
  <view class="warning" wx:if="{{prepaymentType === 'partial' && prepaymentAmount && isNaN(parseFloat(prepaymentAmount))}}">
    <text>请输入有效的还款金额（数字）</text>
  </view>
  
  <!-- 计算按钮 -->
  <button 
    class="calculate-btn {{isFormValid ? '' : 'disabled'}}" 
    bindtap="onCalculate"
    disabled="{{!isFormValid}}"
  >
    计算还款详情
  </button>
  
  <!-- 计算结果 -->
  <view class="result-container" wx:if="{{showResult}}">
    <text class="result-title">还款计算结果</text>
    
    <view class="result-summary">
      <view class="summary-item">
        <text>贷款剩余本金</text>
        <text class="summary-value">{{results.remainingPrincipal}}元</text>
      </view>
      
      <view class="summary-item">
        <text>当月需还款</text>
        <text class="summary-value">{{results.currentMonthPayment}}元</text>
      </view>
      
      <view class="summary-item">
        <text>已还利息</text>
        <text class="summary-value">{{results.paidInterest}}元</text>
      </view>
    </view>
    
    <!-- 两种还款方式结果 -->
    <view class="repayment-methods">
      <!-- 方式一：月供不变，期限缩短 -->
      <view class="method-card method1">
        <text class="method-title">{{results.method1.name}}</text>
        
        <view class="result-row">
          <text>次月还款额</text>
          <text class="amount">{{results.method1.newMonthlyPayment}}元</text>
        </view>
        
        <view class="result-row">
          <text>节省利息</text>
          <text class="amount savings">{{results.method1.savings}}元</text>
        </view>
        
        <view class="result-row">
          <text>新还款期限</text>
          <text class="amount">{{results.method1.newTerm > 0 ? results.method1.newTerm + '个月' : '已结清'}}</text>
        </view>
        
        <view class="result-row">
          <text>最后还款日</text>
          <text class="amount">{{results.method1.finalRepaymentDate}}</text>
        </view>
      </view>
      
      <!-- 方式二：期限不变，月供减少 -->
      <view class="method-card method2">
        <text class="method-title">{{results.method2.name}}</text>
        
        <view class="result-row">
          <text>次月还款额</text>
          <text class="amount">{{results.method2.newMonthlyPayment}}元</text>
        </view>
        
        <view class="result-row">
          <text>月供减少额</text>
          <text class="amount savings">{{results.method2.monthlyReduction}}元</text>
        </view>
        
        <view class="result-row">
          <text>节省利息</text>
          <text class="amount savings">{{results.method2.savings}}元</text>
        </view>
        
        <view class="result-row">
          <text>最后还款日</text>
          <text class="amount">{{results.method2.finalRepaymentDate}}</text>
        </view>
      </view>
    </view>
    
    <!-- 贷款类型提示 -->
    <view class="loan-type-hint">
      <text>当前计算基于{{loanType === 'commercial' ? '商业贷款' : '公积金贷款'}}（{{repaymentType === 'equal' ? '等额本息' : '等额本金'}}）</text>
    </view>
  </view>
  
  <!-- 结果图表 -->
  <!-- <view class="chart-container" wx:if="{{showResult}}">
    <text class="result-title">利息分布图</text>
    <view class="chart">
      <view class="chart-bar" style="width:{{results.chartData[0].percent}}; background-color: #4CAF50;"></view>
      <view class="chart-bar" style="width:{{results.chartData[1].percent}}; background-color: #2196F3;"></view>
    </view>
    <view class="chart-legend">
      <view class="legend-item"><view class="color-box" style="background-color:#4CAF50;"></view><text>已付利息: {{results.chartData[0].value.toFixed(2)}}元</text></view>
      <view class="legend-item"><view class="color-box" style="background-color:#2196F3;"></view><text>节省利息: {{results.chartData[1].value.toFixed(2)}}元</text></view>
    </view>
  </view> -->
  
  <!-- 计算结果说明 -->
  <view class="notice" wx:if="{{showResult}}">
    <text class="notice-title">计算结果说明</text>
    <text>1. "月供不变，期限缩短"：保持每月还款额不变，但减少还款月数</text>
    <text>2. "期限不变，月供减少"：保持还款期限不变，但降低每月还款额</text>
    <text>3. 节省利息 = 原还款计划利息 - 提前还款后利息</text>
    <text>4. 所有计算结果仅供参考，具体以银行实际计算结果为准</text>
  </view>
</view>
